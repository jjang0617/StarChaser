# ──────────────────────────────────────────
# StarChaser 모노레포 .gitignore
# ──────────────────────────────────────────

# 환경변수 — 절대 커밋 금지
.env
.env.*
!.env.example

# 의존성
node_modules/

# 빌드 결과물
dist/
build/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
# .vscode/extensions.json 은 팀 공유용 → 커밋 OK

# ──────────────────────────────────────────
# Backend (NestJS)
# ──────────────────────────────────────────
backend/.env
backend/.env.*
!backend/.env.example
backend/dist/
backend/node_modules/

# ──────────────────────────────────────────
# Frontend (React Native + Expo)
# ──────────────────────────────────────────
frontend/.expo/
frontend/node_modules/
frontend/.env
frontend/.env.*
!frontend/.env.example

# Expo
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*
web-build/

# ──────────────────────────────────────────
# 로그
# ──────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ──────────────────────────────────────────
# 테스트 / 커버리지
# ──────────────────────────────────────────
coverage/
*.lcov
.nyc_output/

# ──────────────────────────────────────────
# 기타
# ──────────────────────────────────────────
*.tsbuildinfo
.npm
.eslintcache
.yarn-integrity
