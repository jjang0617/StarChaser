# ──────────────────────────────────────────
# backend/.env.example
# 값은 팀 단톡에서 공유. 이 파일은 커밋 O / .env는 커밋 절대 금지
# ──────────────────────────────────────────

# DB (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# 캐시 (Phase 1: memory / Phase 2: redis)
CACHE_DRIVER=memory
CACHE_TTL=3600

# JWT
JWT_SECRET=최소_32자_이상_랜덤_문자열_입력
JWT_REFRESH_SECRET=최소_32자_이상_다른_랜덤_문자열
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# 기상청 단기예보 API
KMA_API_KEY=

# 에어코리아 PM2.5 API
AIRKOREA_API_KEY=

# KASI 한국천문연구원
KASI_API_KEY=

# Kakao
KAKAO_REST_API_KEY=
KAKAO_JS_KEY=

# FCM Push 알림
FCM_SERVER_KEY=

# 서버 포트 (로컬 Windows에서 3000 EACCES 시 3333 권장 — Railway는 플랫폼이 PORT 지정)
PORT=3333

# ── Phase 2 이후 추가 예정 ──────────────────
# CACHE_DRIVER=redis
# REDIS_URL=
# SENTRY_DSN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_CLOUDFRONT_URL=
