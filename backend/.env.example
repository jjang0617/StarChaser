# ──────────────────────────────────────────
# backend/.env.example
# 값은 팀 단톡에서 공유. 이 파일은 커밋 O / .env는 커밋 절대 금지
# ──────────────────────────────────────────

# production (Railway 필수) — CORS·Swagger·오류 메시지 마스킹
NODE_ENV=production

# DB (Supabase)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres

# Supabase Storage (프로필 사진) — Dashboard → Settings → API
# 버킷 avatars, diary-photos 생성, Public bucket 체크
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=service_role_...

# 캐시 — memory(기본) | redis (재시작 후에도 weather/dust/moon 유지)
CACHE_DRIVER=memory
CACHE_TTL=3600
# REDIS_URL=redis://localhost:6379

# 서버 기동 시 Star-Index 입력 캐시 백그라운드 워밍 (false 로 끔)
STAR_INDEX_WARM_ON_STARTUP=true

# JWT
JWT_SECRET=최소_32자_이상_랜덤_문자열_입력
JWT_REFRESH_SECRET=최소_32자_이상_다른_랜덤_문자열
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# 관리자 (불일치 제보 대시보드) — 쉼표로 여러 이메일
ADMIN_EMAILS=you@example.com

# 기상청 단기예보 API
KMA_API_KEY=

# 에어코리아 PM2.5 API
AIRKOREA_API_KEY=

# KASI 한국천문연구원 (달·출몰; 분리 키 없으면 KASI_API_KEY 사용)
KASI_API_KEY=
# KASI_MOON_API_KEY=
# KASI_RISE_SET_API_KEY=

# Kakao
# 카카오 Developers → 앱 → REST API 키 (로컬 장소 검색 /places/search)
KAKAO_REST_API_KEY=
# 카카오 Developers → JavaScript 키 (지도 WebView)
KAKAO_JS_KEY=

# ── FCM (Firebase Cloud Messaging, 서버 발송용) ────────────────────────
# Firebase 콘솔 → 프로젝트 설정 → 서비스 계정 → Admin SDK 에서 받은 JSON의
# project_id / client_email / private_key 만 .env 에 넣는 방식 (= 파일 경로 대신 방법 2).
# private_key 는 JSON 안의 줄바꿈을 \n 문자로 이어붙인 한 줄로 넣고, 코드에서
# .replace(/\\n/g, '\n') 로 복구한다. 통째 넣으려면 Base64 한 줄 변수를 쓰는 편이 낫다.
# 이 값은 매우 민감함 — 팀 보안 채널만, Git 커밋 금지. 로컬에만 받을 사람은 백엔드 담변.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@프로젝트.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# production 에서도 POST /notifications/test-send 를 쓰려면 true (기본은 production 에서 비활성)
# FCM_TEST_SEND_ENABLED=true

# 매시 15분 KST — Star-Index 임계 알림 (기준 명소 + 위치한 곳 GPS) 당일 1회 푸시.
# 위치한 곳은 앱이 POST /notifications/observer-location 으로 보고한 좌표(최근 7일) 사용.
# FCM_SCHEDULED_STAR_INDEX_PUSH_ENABLED=true
# STAR_INDEX_ALERT_THRESHOLD=90

# production 에서 POST /notifications/dev/run-star-index-scheduled-push 로 스케줄을 즉시 돌리려면 true (개발은 NODE_ENV≠production 이면 생략 가능)
# FCM_STAR_INDEX_MANUAL_TRIGGER_ENABLED=true

# 서버 포트 (로컬 Windows에서 3000 EACCES 시 3333 권장 — Railway는 플랫폼이 PORT 지정)
PORT=3333
# 기본은 개발에서 127.0.0.1 만 listen → 폰으로 http://PC Wi-Fi IP:PORT 접속 시 타임아웃.
# 실기/Expo에서 같은 망의 PC API 쓰려면 개발 시에만 HOST=0.0.0.0 (방화벽 3333 허용 필요)
# HOST=0.0.0.0

# ── SMTP (이메일 인증번호 발송) ──────────────────
# 미설정 시 인증번호가 서버 콘솔에만 출력됩니다 (개발용)
# 발송 전용 Gmail (앱 비밀번호 필요, 일반 비밀번호 X)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=StarChaser <no-reply@starchaser.app>

# ── Phase 2 이후 추가 예정 ──────────────────
# CACHE_DRIVER=redis
# REDIS_URL=
# SENTRY_DSN=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_CLOUDFRONT_URL=
