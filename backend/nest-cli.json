{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "tsConfigPath": "tsconfig.build.json",
    "assets": [
      {
        "include": "sky/data/*.json",
        "watchAssets": true
      },
      {
        "include": "cache-hydration/data/*.json",
        "watchAssets": true
      }
    ]
  }
}
