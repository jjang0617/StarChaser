# 백엔드 주소(ipconfig 로 본 PC Wi‑Fi IP)·폰 테스트 시 http://<PC_WiFi_IP>:3333 / 끝에 / 없음 · 고친 뒤 expo 재시작
EXPO_PUBLIC_API_URL=http://<PC_WiFi_IP>:3333

# Star-Index 카드에 쓸 명소 UUID (spots.id) — 시드 후 DB/Swagger에서 복사
EXPO_PUBLIC_DEFAULT_SPOT_ID=

# (선택) 카카오맵 — 아래 URL 호스트를 Kakao Developers → JavaScript SDK 도메인에 등록
# EXPO_PUBLIC_KAKAO_JAVASCRIPT_KEY=
# EXPO_PUBLIC_KAKAO_MAP_PAGE_URL=https://<owner>.github.io/<repo>/kakao.html
# (선택) 로컬: 콘솔에 http://<PC_WiFi_IP>:3333 추가 등록 후
# EXPO_PUBLIC_KAKAO_MAP_PAGE_URL=http://<PC_WiFi_IP>:3333/kakao.html
